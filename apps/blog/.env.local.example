# =============================================================
# 博客应用 (apps/blog) 环境变量配置模板
# =============================================================
# 使用方法：
#   将此文件复制为 .env.local，然后填入真实值
#   cp .env.local.example .env.local
#
# 注意：.env.local 包含敏感信息，已在 .gitignore 中排除，
#       请勿将真实密钥提交到代码仓库。
# =============================================================


# -------------------------------------------------------------
# [必填] Supabase 项目地址
# 获取路径：Supabase 控制台 → 项目 → Settings → API → Project URL
# 格式：https://<project-id>.supabase.co
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co


# -------------------------------------------------------------
# [必填] Supabase 匿名公钥（anon key）
# 获取路径：Supabase 控制台 → 项目 → Settings → API → anon public
# 说明：该密钥可安全暴露在前端，受 Row Level Security (RLS) 保护
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# -------------------------------------------------------------
# [可选] Supabase 服务角色密钥（service_role key）
# 获取路径：Supabase 控制台 → 项目 → Settings → API → service_role
# 说明：拥有完整数据库写权限，仅在服务端使用，绝不可暴露到前端
#       填写此项后，服务端 Supabase 客户端将优先使用该密钥（绕过 RLS）
#       当前仅需读取博客文章，此项可留空
# -------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# -------------------------------------------------------------
# [可选] 站点根地址
# 用途：用于生成 sitemap、canonical URL 和 OG 元数据的 metadataBase
# 本地开发留空即可，Next.js 会自动回退到 http://localhost:3000
# 生产环境填写正式域名（不含末尾斜杠）
# -------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://xadyz.com
