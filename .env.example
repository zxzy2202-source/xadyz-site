# =============================================================
# 主网站 (Vite) 环境变量配置模板
# =============================================================
# 使用方法：
#   将此文件复制为 .env，然后填入真实值
#   cp .env.example .env
#
# 注意：.env 已在 .gitignore 中排除，请勿提交真实值。
# =============================================================


# -------------------------------------------------------------
# [可选] Strapi CMS 地址
# 说明：当前主网站内容为静态数据，Strapi 暂未启用
#       如需对接 Strapi，填写其运行地址
# 默认值：http://localhost:1337
# -------------------------------------------------------------
VITE_STRAPI_URL=http://localhost:1337
